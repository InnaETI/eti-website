{
  "name": "eti-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next-dev",
    "dev": "next dev --hostname 0.0.0.0 --port 3010",
    "dev:turbopack": "next dev --turbopack --hostname 0.0.0.0 --port 3010",
    "dev:clean": "rm -rf .next .next-dev && npm run dev",
    "prebuild": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit && next build",
    "smoke": "tsc --noEmit && next build",
    "lint": "next lint",
    "postbuild": "next-sitemap",
    "fetch-wordpress": "node scripts/fetch-wordpress.mjs"
  },
  "dependencies": {
    "next": "^15.5.11",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "swiper": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}

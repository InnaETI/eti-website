{
  "name": "eti-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next-dev",
    "dev": "next dev --hostname 0.0.0.0 --port 3010",
    "dev:turbopack": "next dev --turbopack --hostname 0.0.0.0 --port 3010",
    "dev:clean": "rm -rf .next .next-dev && npm run dev",
    "prebuild": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit && next build",
    "smoke": "tsc --noEmit && next build",
    "lint": "next lint",
    "postbuild": "next-sitemap",
    "fetch-wordpress": "node scripts/fetch-wordpress.mjs"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "next": "15.5.14",
    "next-sitemap": "4.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "9.0.0",
    "resend": "^6.10.0",
    "swiper": "12.1.0"
  },
  "devDependencies": {
    "@types/node": "22.18.0",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.5",
    "autoprefixer": "10.4.21",
    "eslint": "9.35.0",
    "eslint-config-next": "15.5.14",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2"
  }
}
